# Display names — set SITE_NAME to your house name (shown in header & footer)
COMPANY_NAME="Your Company"
SITE_NAME="Maison Lumière"

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
# Optional server-only alias (same value as above if you prefer not to use NEXT_PUBLIC_ here)
# SUPABASE_URL=
# Anon JWT or dashboard “Publishable / default” key (either is fine)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Server-only — required for orders at checkout, webhooks, `npm run seed:products` (never expose client-side)
# Supabase → Project Settings → API → service_role (secret), not anon
SUPABASE_SERVICE_ROLE_KEY=
# Optional alias:
# SERVICE_ROLE_KEY=

# Apply migrations to your hosted DB (after: npx supabase login && npx supabase link --project-ref <ref>)
#   npm run db:push
# Then seed demo products:
#   npm run seed:products

# Stripe — Dashboard → Developers → API keys (use test keys locally)
# Webhook: Dashboard → Developers → Webhooks → endpoint https://<your-domain>/api/webhooks/stripe
#   Events: checkout.session.completed   Signing secret → STRIPE_WEBHOOK_SECRET
# Server secret: use STRIPE_SECRET_KEY or alias STRIPE_SECRET (sk_live_… / sk_test_…)
STRIPE_SECRET_KEY=
# STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Public site URL for Stripe return URLs and resolving relative product images on Checkout (use HTTPS in production; required for Stripe to show images)
NEXT_PUBLIC_SITE_URL=

# Optional — welcome modal only: forward to an external ESP after Supabase (footer uses Supabase only)
# NEXT_PUBLIC_NEWSLETTER_FORM_ACTION=
